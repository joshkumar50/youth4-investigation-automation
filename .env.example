# ═══════════════════════════════════════════════════════
# Investigation Intelligence Platform — Environment Config
# Copy this file to .env and fill in values before running
# ═══════════════════════════════════════════════════════

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# ───────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────
POSTGRES_DB=investigation_db
POSTGRES_USER=iip_user
POSTGRES_PASSWORD=iip_secret_2024

# ───────────────────────────────────────
# Redis
# ───────────────────────────────────────
REDIS_PASSWORD=iip_redis_2024

# ───────────────────────────────────────
# MinIO Object Storage
# ───────────────────────────────────────
MINIO_ROOT_USER=iip_minio
MINIO_ROOT_PASSWORD=iip_minio_secret_2024
MINIO_BUCKET_NAME=investigation-evidence

# ───────────────────────────────────────
# ChromaDB
# ───────────────────────────────────────
CHROMA_TOKEN=iip_chroma_token

# ───────────────────────────────────────
# JWT Authentication
# ───────────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ───────────────────────────────────────
# AI / ML
# ───────────────────────────────────────
SPACY_MODEL=en_core_web_sm
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://ollama:11434
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ───────────────────────────────────────
# Celery / Flower
# ───────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin123

# ───────────────────────────────────────
# Frontend
# ───────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
